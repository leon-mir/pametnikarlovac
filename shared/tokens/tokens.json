{
  "$description": "Pametni Karlovac design tokeni. Izvor istine: shared/design-system.md. Sve brand boje potječu sa stvarnih mjesta u Karlovcu. Kontrasti izračunati po WCAG relativnoj luminanciji (provjereno 18.7.2026.).",
  "color": {
    "brand": {
      "primary": { "value": "#15404A", "origin": "prosjek boja 4 rijeke s Google Mapsa (Korana #09313A, Kupa #19424A, Mrežnica #193D48, Dobra #19515A)" },
      "bg": { "value": "#FAF7F2", "origin": "topla bijela" },
      "surface": { "value": "#FFFFFF" },
      "gold": { "value": "#D89F1F", "origin": "novi križ tornja crkve sv. Trojstva", "warning": "nikad mali tekst na svijetloj podlozi (2.2:1)" },
      "gold-text": { "value": "#8A6408", "derived": true, "contrastOnBg": "5.0:1 AA" },
      "patina": { "value": "#4D9397", "origin": "zvonik (vrh) tornja crkve sv. Trojstva", "warning": "samo dekoracija/veliki elementi (3.3:1 na bg)" },
      "patina-strong": { "value": "#256066", "derived": true, "contrastOnBg": "6.7:1 AA", "whiteOnIt": "7.2:1 AAA" },
      "roof": { "value": "#9C6D5A", "origin": "krovovi u Zvijezdi", "warning": "samo dekoracija/veliki elementi (4.1:1 na bg)" },
      "roof-strong": { "value": "#7A5142", "derived": true, "contrastOnBg": "6.4:1 AA" },
      "danger": { "value": "#E32213", "origin": "crvena s grba grada", "warning": "za mali tekst koristiti danger-strong" },
      "danger-strong": { "value": "#B81B0F", "derived": true, "contrastOnBg": "6.1:1 AA", "whiteOnIt": "6.6:1 AA" },
      "success": { "value": "#0D5736", "origin": "zelena s grba grada", "contrastOnBg": "8.1:1 AAA" }
    },
    "river": {
      "korana": { "value": "#09313A", "origin": "Korana kod Foginovog kupališta" },
      "kupa": { "value": "#19424A", "origin": "Kupa kod Banijskog mosta" },
      "mreznica": { "value": "#193D48", "origin": "Mrežnica na ušću u Koranu" },
      "dobra": { "value": "#19515A", "origin": "Dobra prije ušća u Kupu" }
    },
    "semantic": {
      "text": { "value": "{color.brand.primary}" },
      "text-muted": { "value": "#5C6B70", "contrastOnBg": "5.2:1 AA" },
      "text-inverse": { "value": "#FFFFFF" },
      "border-subtle": { "value": "#E7E0D5", "note": "samo dekorativno" },
      "border-strong": { "value": "#5C6B70", "note": "rubovi inputa i interaktivnih elemenata" },
      "focus": { "value": "{color.brand.gold}" }
    },
    "accentByApp": {
      "hub": { "accent": "gold", "accentText": "gold-text", "accentContrast": "primary" },
      "bus": { "accent": "gold", "accentText": "gold-text", "accentContrast": "primary" },
      "proracun": { "accent": "patina-strong", "accentText": "patina-strong", "accentContrast": "#FFFFFF" },
      "dogadaji": { "accent": "roof-strong", "accentText": "roof-strong", "accentContrast": "#FFFFFF" }
    },
    "dataViz": {
      "categorical": ["#15404A", "#4D9397", "#D89F1F", "#9C6D5A"],
      "sequential": ["#09313A", "#193D48", "#19424A", "#19515A"],
      "note": "kategorijski max 4 serije pa 'Ostalo'; nikad crveno/zeleno kao jedini signal"
    }
  },
  "font": {
    "family": "Manrope, Inter, system-ui, sans-serif",
    "weights": { "regular": 400, "semibold": 600, "extrabold": 800 },
    "size": {
      "mega": 40, "display": 32, "h1": 28, "h2": 24, "h3": 22,
      "body-lg": 20, "body": 18, "caption": 16
    },
    "userScale": { "normalna": 1.0, "velika": 1.15, "najveca": 1.3 },
    "lineHeight": { "text": 1.5, "tight": 1.2 },
    "rules": ["min UI tekst 18px (Bus 20px)", "tabular-nums za vremena i iznose", "caption samo za sporedno"]
  },
  "space": [4, 8, 12, 16, 24, 32, 48, 64],
  "radius": { "sm": 8, "md": 12, "lg": 16, "full": 999 },
  "shadow": { "card": "0 1px 3px rgba(21,64,74,0.12)" },
  "tap": { "min": 48, "gap": 8 },
  "layout": { "maxContentWidth": 480, "maxDataWidth": 960, "screenPadding": { "mobile": 16, "tablet": 24 }, "breakpoints": { "tablet": 768, "desktop": 1024 } },
  "zIndex": { "header": 50, "nav": 100, "banner": 200, "toast": 300 },
  "contrastCheck": {
    "formula": "WCAG 2.1 relativna luminancija; (L1+0.05)/(L2+0.05)",
    "python": "def lum(h):\n    h=h.lstrip('#'); r,g,b=[int(h[i:i+2],16)/255 for i in (0,2,4)]\n    f=lambda c: c/12.92 if c<=0.03928 else ((c+0.055)/1.055)**2.4\n    return 0.2126*f(r)+0.7152*f(g)+0.0722*f(b)\ndef cr(a,b):\n    la,lb=sorted((lum(a),lum(b)),reverse=True)\n    return (la+0.05)/(lb+0.05)"
  }
}
